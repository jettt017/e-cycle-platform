# Backend Environment Variables
# Copy this file to .env and fill in your values
# Set ALL of these in Vercel Dashboard → Settings → Environment Variables

# PostgreSQL connection string (from Supabase/Neon/etc)
DATABASE_URL="postgresql://user:password@host:5432/dbname?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/dbname"

# Server port (Vercel sets this automatically, keep for local dev)
PORT=5000

# Google Gemini API Key (get free key at aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend production URL (for CORS allowlist)
# Example: https://e-cycle.vercel.app
FRONTEND_URL=https://your-frontend.vercel.app
