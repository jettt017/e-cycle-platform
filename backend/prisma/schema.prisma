/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_impacts {
  id                           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id                      String   @unique @db.Uuid
  total_devices_recycled       Int      @default(0)
  total_weight_recycled_kg     Decimal  @default(0) @db.Decimal(12, 3)
  total_heavy_metal_avoided_kg Decimal  @default(0) @db.Decimal(12, 4)
  total_co2_avoided_kg         Decimal  @default(0) @db.Decimal(12, 4)
  total_material_recycled_kg   Decimal  @default(0) @db.Decimal(12, 3)
  total_water_saved_liter      Decimal  @default(0) @db.Decimal(12, 2)
  total_points_earned          Int      @default(0)
  total_points_redeemed        Int      @default(0)
  total_reward_value           Decimal  @default(0) @db.Decimal(14, 2)
  last_updated_at              DateTime @default(now()) @db.Timestamptz(6)
  created_at                   DateTime @default(now()) @db.Timestamptz(6)

  @@index([user_id], map: "idx_user_impacts_user")
}

enum content_type {
  article
