generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  auth_id        String?   @unique @db.Uuid
  full_name      String    @db.VarChar(150)
  email          String    @unique @db.VarChar(255)
  phone          String?   @db.VarChar(20)
  role           user_role @default(consumer)
  user_type      user_type @default(individual)
  avatar_url     String?
  province       String?   @db.VarChar(100)
  city           String?   @db.VarChar(100)
  district       String?   @db.VarChar(100)
  address_detail String?
  latitude       Decimal?  @db.Decimal(10, 8)
  longitude      Decimal?  @db.Decimal(11, 8)
  totalPoints    Int       @default(0) @map("total_points")
  level          Int       @default(1)
  badge_count    Int       @default(0)
  is_verified    Boolean   @default(false)
  is_active      Boolean   @default(true)
  last_login_at  DateTime? @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at     DateTime  @default(now()) @db.Timestamptz(6)

  @@map("users")
}

model ecycle_drop_points {
  id              Int       @id @default(autoincrement())
  name            String
  address         String
  latitude        Float?
  longitude       Float?
  operating_hours String?
  created_at      DateTime? @default(now()) @db.Timestamp(6)
}

model ecycle_transaction_items {
  id                Int   @id @default(autoincrement())
  transaction_id    Int?
  waste_category_id Int?
  weight_kg         Float
  points_earned     Int
}

model ecycle_transactions {
  id                  Int       @id @default(autoincrement())
  user_id             Int?
  drop_point_id       Int?
  status              String?   @default("pending")
  total_points_earned Int?      @default(0)
  created_at          DateTime? @default(now()) @db.Timestamp(6)
}

model ecycle_users {
  id            Int       @id @default(autoincrement())
  name          String
  email         String    @unique
  password_hash String
  role          String?   @default("user")
  total_points  Int?      @default(0)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
}

model ecycle_waste_categories {
  id            Int     @id @default(autoincrement())
  name          String
  points_per_kg Int
  description   String?
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model partner_device_types {
  id         String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partner_id String          @db.Uuid
  category   device_category
  notes      String?
  is_active  Boolean         @default(true)
  created_at DateTime        @default(now()) @db.Timestamptz(6)

  @@index([category], map: "idx_partner_device_types_category")
  @@index([partner_id], map: "idx_partner_device_types_partner")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model partner_reviews {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partner_id    String    @db.Uuid
  user_id       String    @db.Uuid
  submission_id String?   @db.Uuid
  rating        Int       @db.SmallInt
  review_text   String?
  image_urls    String[]
  is_published  Boolean   @default(true)
  partner_reply String?
  replied_at    DateTime? @db.Timestamptz(6)
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime  @default(now()) @db.Timestamptz(6)

  @@unique([user_id, submission_id])
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model partners {
  id                String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id           String?        @db.Uuid
  name              String         @db.VarChar(200)
  partner_type      partner_type
  status            partner_status @default(pending)
  registration_no   String?        @db.VarChar(100)
  tax_id            String?        @db.VarChar(50)
  certificate_url   String?
  epr_registered    Boolean?       @default(false)
  email             String?        @db.VarChar(255)
  phone             String?        @db.VarChar(20)
  website           String?        @db.VarChar(255)
  contact_person    String?        @db.VarChar(150)
  province          String         @db.VarChar(100)
  city              String         @db.VarChar(100)
  district          String?        @db.VarChar(100)
  full_address      String
  latitude          Decimal        @db.Decimal(10, 8)
  longitude         Decimal        @db.Decimal(11, 8)
  operating_hours   Json?
  total_received_kg Decimal?       @default(0) @db.Decimal(12, 2)
  avg_rating        Decimal?       @default(0) @db.Decimal(3, 2)
  review_count      Int?           @default(0)
  description       String?
  logo_url          String?
  image_urls        String[]
  created_at        DateTime       @default(now()) @db.Timestamptz(6)
  updated_at        DateTime       @default(now()) @db.Timestamptz(6)

  @@index([city], map: "idx_partners_city")
  @@index([latitude, longitude], map: "idx_partners_location")
  @@index([status], map: "idx_partners_status")
  @@index([partner_type], map: "idx_partners_type")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model pickups {
  id                   String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  submission_id        String        @db.Uuid
  user_id              String        @db.Uuid
  logistics_partner_id String?       @db.Uuid
  scheduled_date       DateTime      @db.Date
  scheduled_time_start DateTime      @db.Time(6)
  scheduled_time_end   DateTime      @db.Time(6)
  status               pickup_status @default(scheduled)
  pickup_address       String
  pickup_province      String?       @db.VarChar(100)
  pickup_city          String?       @db.VarChar(100)
  pickup_district      String?       @db.VarChar(100)
  pickup_latitude      Decimal?      @db.Decimal(10, 8)
  pickup_longitude     Decimal?      @db.Decimal(11, 8)
  courier_name         String?       @db.VarChar(150)
  courier_phone        String?       @db.VarChar(20)
  vehicle_plate        String?       @db.VarChar(15)
  picked_up_at         DateTime?     @db.Timestamptz(6)
  delivered_at         DateTime?     @db.Timestamptz(6)
  failure_reason       String?
  notes                String?
  created_at           DateTime      @default(now()) @db.Timestamptz(6)
  updated_at           DateTime      @default(now()) @db.Timestamptz(6)

  @@index([scheduled_date], map: "idx_pickups_date")
  @@index([status], map: "idx_pickups_status")
  @@index([submission_id], map: "idx_pickups_submission")
  @@index([user_id], map: "idx_pickups_user")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model points_transactions {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id          String   @db.Uuid
  submission_id    String?  @db.Uuid
  transaction_type String   @db.VarChar(50)
  points           Int
  balance_after    Int
  description      String?
  reference_id     String?  @db.Uuid
  created_at       DateTime @default(now()) @db.Timestamptz(6)

  @@index([created_at(sort: Desc)], map: "idx_points_transactions_created")
  @@index([user_id], map: "idx_points_transactions_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model submissions {
  id              String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  submission_code String            @unique @db.VarChar(20)
  user_id         String            @db.Uuid
  partner_id      String?           @db.Uuid
  estimation_id   String?           @db.Uuid
  method          submission_method @default(drop_off)
  status          submission_status @default(draft)
  devices_detail  Json
  total_items     Int               @default(1)
  total_weight_kg Decimal?          @db.Decimal(8, 3)
  reward_type     reward_type?      @default(points)
  reward_amount   Decimal?          @default(0) @db.Decimal(12, 2)
  reward_paid_at  DateTime?         @db.Timestamptz(6)
  user_notes      String?
  partner_notes   String?
  admin_notes     String?
  proof_images    String[]
  receipt_images  String[]
  submitted_at    DateTime?         @db.Timestamptz(6)
  confirmed_at    DateTime?         @db.Timestamptz(6)
  received_at     DateTime?         @db.Timestamptz(6)
  completed_at    DateTime?         @db.Timestamptz(6)
  cancelled_at    DateTime?         @db.Timestamptz(6)
  cancel_reason   String?
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  updated_at      DateTime          @default(now()) @db.Timestamptz(6)

  @@index([submission_code], map: "idx_submissions_code")
  @@index([created_at(sort: Desc)], map: "idx_submissions_created")
  @@index([partner_id], map: "idx_submissions_partner")
  @@index([status], map: "idx_submissions_status")
  @@index([user_id], map: "idx_submissions_user")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
